   "source": [
    "x=df_peng.groupby(\"species\")[\"body_mass_g\"].mean()\n",
    "resultado = max(x.items(), key=lambda x: x[1]) # items() devuelve una vista de los pares clave-valor del Series, y max() encuentra el par con el valor máximo utilizando una función lambda para comparar los valores.\n",
    "                                               # La función lambda toma cada par clave-valor (x) y devuelve el valor (x[1]) para que max() pueda comparar los valores y encontrar el máximo.\n",
    "print(resultado)"
